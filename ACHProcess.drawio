        <mxCell id="kZJG9KBWsuVOy66hwry9-498" parent="1" style="shape=note;strokeWidth=2;fontSize=14;size=20;whiteSpace=wrap;html=1;fillColor=#76608a;strokeColor=#432D57;fontColor=#ffffff;align=left;" value="&lt;font style=&quot;font-size: 56px;&quot;&gt;Summary - What to do&lt;/font&gt;" vertex="1">
          <mxGeometry height="90" width="850" x="9850" y="230" as="geometry" />
        </mxCell>
        <mxCell id="kZJG9KBWsuVOy66hwry9-499" parent="1" style="shape=note;strokeWidth=2;fontSize=14;size=20;whiteSpace=wrap;html=1;fillColor=#76608a;strokeColor=#432D57;fontColor=#ffffff;align=left;" value="&lt;font style=&quot;font-size: 56px;&quot;&gt;1. Store the transactions until ready to send&lt;/font&gt;" vertex="1">
          <mxGeometry height="180" width="860" x="9850" y="360" as="geometry" />
        </mxCell>
        <mxCell id="kZJG9KBWsuVOy66hwry9-501" parent="1" style="shape=note;strokeWidth=2;fontSize=14;size=20;whiteSpace=wrap;html=1;fillColor=#76608a;strokeColor=#432D57;fontColor=#ffffff;align=left;" value="&lt;font style=&quot;font-size: 56px;&quot;&gt;2. Convert transactions into .ach&lt;/font&gt;" vertex="1">
          <mxGeometry height="100" width="860" x="9850" y="560" as="geometry" />
        </mxCell>
        <mxCell id="kZJG9KBWsuVOy66hwry9-502" parent="1" style="shape=note;strokeWidth=2;fontSize=14;size=20;whiteSpace=wrap;html=1;fillColor=#647687;strokeColor=#314354;fontColor=#ffffff;align=left;" value="&lt;font style=&quot;font-size: 56px;&quot;&gt;3. Upload .ach into your SFTP account&lt;/font&gt;" vertex="1">
          <mxGeometry height="160" width="860" x="9850" y="680" as="geometry" />
        </mxCell>
        <mxCell id="kZJG9KBWsuVOy66hwry9-503" parent="1" style="shape=note;strokeWidth=2;fontSize=14;size=20;whiteSpace=wrap;html=1;fillColor=#fa6800;strokeColor=#C73500;fontColor=#000000;align=left;" value="&lt;font style=&quot;font-size: 56px;&quot;&gt;4. Run &quot;collect&quot; - Manually&amp;nbsp;&lt;/font&gt;" vertex="1">
          <mxGeometry height="100" width="860" x="9850" y="870" as="geometry" />
        </mxCell>
        <mxCell id="kZJG9KBWsuVOy66hwry9-504" parent="1" style="shape=note;strokeWidth=2;fontSize=14;size=20;whiteSpace=wrap;html=1;fillColor=#fa6800;strokeColor=#C73500;fontColor=#000000;align=left;" value="&lt;font style=&quot;font-size: 56px;&quot;&gt;5. Run &quot;session&quot;&amp;nbsp;&lt;/font&gt;&lt;span style=&quot;font-size: 56px;&quot;&gt;- Manually&lt;/span&gt;" vertex="1">
          <mxGeometry height="100" width="860" x="9850" y="1000" as="geometry" />
        </mxCell>
        <mxCell id="kZJG9KBWsuVOy66hwry9-526" edge="1" parent="1" source="kZJG9KBWsuVOy66hwry9-505" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=6;fillColor=#6d8764;strokeColor=#3A5431;" target="kZJG9KBWsuVOy66hwry9-524">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="10780" y="1195" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="kZJG9KBWsuVOy66hwry9-505" parent="1" style="shape=note;strokeWidth=2;fontSize=14;size=20;whiteSpace=wrap;html=1;fillColor=#647687;strokeColor=#314354;fontColor=#ffffff;align=left;" value="&lt;span style=&quot;font-size: 56px;&quot;&gt;6. Get your processed file from SFTP account&lt;/span&gt;" vertex="1">
          <mxGeometry height="150" width="860" x="9850" y="1120" as="geometry" />
        </mxCell>
        <mxCell id="kZJG9KBWsuVOy66hwry9-506" parent="1" style="shape=note;strokeWidth=2;fontSize=14;size=20;whiteSpace=wrap;html=1;fillColor=#76608a;strokeColor=#432D57;fontColor=#ffffff;align=left;" value="&lt;span style=&quot;font-size: 56px;&quot;&gt;7. Update the accounts on your end&lt;/span&gt;" vertex="1">
          <mxGeometry height="150" width="860" x="9850" y="1300" as="geometry" />
        </mxCell>
        <mxCell id="kZJG9KBWsuVOy66hwry9-507" parent="1" style="shape=note;strokeWidth=2;fontSize=14;size=20;whiteSpace=wrap;html=1;fillColor=#e51400;strokeColor=#B20000;fontColor=#ffffff;align=left;" value="&lt;font style=&quot;font-size: 56px;&quot;&gt;Couple of important notes&lt;/font&gt;" vertex="1">
          <mxGeometry height="90" width="850" x="10850" y="230" as="geometry" />
        </mxCell>
        <mxCell id="kZJG9KBWsuVOy66hwry9-508" parent="1" style="shape=note;strokeWidth=2;fontSize=14;size=20;whiteSpace=wrap;html=1;fillColor=#a0522d;strokeColor=#6D1F00;fontColor=#ffffff;align=left;" value="&lt;font style=&quot;font-size: 56px;&quot;&gt;As you can see there is no confirmation being sent. If there are any problems the banks are supposed to reverse the faulty transaction. If after 3 days,&amp;nbsp;you didn&#39;t receive any returns etc., you can assume the transaction was successful.&lt;/font&gt;" vertex="1">
          <mxGeometry height="580" width="870" x="10850" y="350" as="geometry" />
        </mxCell>
        <mxCell id="kZJG9KBWsuVOy66hwry9-509" parent="1" style="shape=note;strokeWidth=2;fontSize=14;size=20;whiteSpace=wrap;html=1;fillColor=#a0522d;strokeColor=#6D1F00;fontColor=#ffffff;align=left;" value="&lt;font style=&quot;font-size: 56px;&quot;&gt;The money is transferred before the receiving banks are notified.&lt;/font&gt;&lt;div&gt;&lt;font style=&quot;font-size: 56px;&quot;&gt;In ACH system step 3, after session the money is netted, and difference is exchanged between banks. THEN the receiving banks get their processed .ach file informing them about the changes.&lt;/font&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="660" width="870" x="10850" y="950" as="geometry" />
        </mxCell>
        <mxCell id="kZJG9KBWsuVOy66hwry9-510" parent="1" style="shape=note;strokeWidth=2;fontSize=14;size=20;whiteSpace=wrap;html=1;fillColor=#e51400;strokeColor=#B20000;fontColor=#ffffff;align=left;" value="&lt;span style=&quot;font-size: 56px;&quot;&gt;How to handle returns&lt;/span&gt;" vertex="1">
          <mxGeometry height="90" width="870" x="11880" y="230" as="geometry" />
        </mxCell>
        <mxCell id="kZJG9KBWsuVOy66hwry9-511" parent="1" style="shape=note;strokeWidth=2;fontSize=14;size=20;whiteSpace=wrap;html=1;fillColor=#a0522d;strokeColor=#6D1F00;fontColor=#ffffff;align=left;" value="&lt;font style=&quot;font-size: 56px;&quot;&gt;Let&#39;s look at one of the transactions. With code 22.&lt;/font&gt;" vertex="1">
          <mxGeometry height="145" width="870" x="11880" y="355" as="geometry" />
        </mxCell>
        <mxCell id="kZJG9KBWsuVOy66hwry9-512" parent="1" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=default;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/png,;" value="" vertex="1">
          <mxGeometry height="677" width="860.67" x="11880" y="523" as="geometry" />
        </mxCell>
        <mxCell id="kZJG9KBWsuVOy66hwry9-513" parent="1" style="shape=note;strokeWidth=2;fontSize=14;size=20;whiteSpace=wrap;html=1;fillColor=#a0522d;strokeColor=#6D1F00;fontColor=#ffffff;align=left;" value="&lt;span style=&quot;font-size: 56px;&quot;&gt;Let&#39;s say you received this transaction but there is no account with number: 111222333&lt;/span&gt;" vertex="1">
          <mxGeometry height="220" width="870" x="11880" y="1220" as="geometry" />
        </mxCell>
        <mxCell id="kZJG9KBWsuVOy66hwry9-514" parent="1" style="shape=note;strokeWidth=2;fontSize=14;size=20;whiteSpace=wrap;html=1;fillColor=#a0522d;strokeColor=#6D1F00;fontColor=#ffffff;align=left;" value="&lt;span style=&quot;font-size: 56px;&quot;&gt;To reverse it you would want to send the money back. So, let&#39;s swap the sender with receiver.&lt;/span&gt;" vertex="1">
          <mxGeometry height="220" width="870" x="11880" y="1470" as="geometry" />
        </mxCell>
        <mxCell id="kZJG9KBWsuVOy66hwry9-515" parent="1" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=default;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/png,;" value="" vertex="1">
          <mxGeometry height="620" width="868.87" x="11880" y="1710" as="geometry" />
        </mxCell>
        <mxCell id="kZJG9KBWsuVOy66hwry9-516" parent="1" style="shape=note;strokeWidth=2;fontSize=14;size=20;whiteSpace=wrap;html=1;fillColor=#a0522d;strokeColor=#6D1F00;fontColor=#ffffff;align=left;" value="&lt;span style=&quot;font-size: 56px;&quot;&gt;Right away, you can notice, we want to return for non-existent bank account. In this case instead of specific account in header, we put the banks data. So your legal name, and FEIN(you can set it in .env)&lt;/span&gt;" vertex="1">
          <mxGeometry height="520" width="870" x="12780" y="1710" as="geometry" />
        </mxCell>
        <mxCell id="kZJG9KBWsuVOy66hwry9-517" parent="1" style="shape=note;strokeWidth=2;fontSize=14;size=20;whiteSpace=wrap;html=1;fillColor=#a0522d;strokeColor=#6D1F00;fontColor=#ffffff;align=left;" value="&lt;span style=&quot;font-size: 56px;&quot;&gt;Another problem is that there is no account number. As previously mentioned, company id is not the same as account number.&lt;/span&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="300" width="870" x="12780" y="2260" as="geometry" />
        </mxCell>
        <mxCell id="kZJG9KBWsuVOy66hwry9-518" parent="1" style="shape=note;strokeWidth=2;fontSize=14;size=20;whiteSpace=wrap;html=1;fillColor=#a0522d;strokeColor=#6D1F00;fontColor=#ffffff;align=left;" value="&lt;div&gt;&lt;span style=&quot;font-size: 56px;&quot;&gt;Record type 6 has an optional field for the identification number that can help receiving bank process returns. But since it&#39;s optional it&#39;s hard to rely on.&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="390" width="870" x="12780" y="2580" as="geometry" />
        </mxCell>
        <mxCell id="kZJG9KBWsuVOy66hwry9-519" parent="1" style="shape=note;strokeWidth=2;fontSize=14;size=20;whiteSpace=wrap;html=1;fillColor=#a0522d;strokeColor=#6D1F00;fontColor=#ffffff;align=left;" value="&lt;div&gt;&lt;span style=&quot;font-size: 56px;&quot;&gt;In case the sending bank didn&#39;t include the identification number.&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 56px;&quot;&gt;Banks would need to rely on trace number. To avoid this, simply use company_identification as their account number.&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="410" width="870" x="12780" y="2990" as="geometry" />
        </mxCell>
        <mxCell id="kZJG9KBWsuVOy66hwry9-520" parent="1" style="shape=note;strokeWidth=2;fontSize=14;size=20;whiteSpace=wrap;html=1;fillColor=#76608a;strokeColor=#432D57;fontColor=#ffffff;align=left;" value="&lt;div&gt;&lt;span style=&quot;font-size: 56px;&quot;&gt;If you&#39;re a bank make sure to set your clients account number to be the same as their FEIN, or implement the logic to recognize both account number and FEIN in dfi_account_number field for return records&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="480" width="870" x="12780" y="3420" as="geometry" />
        </mxCell>
        <mxCell id="kZJG9KBWsuVOy66hwry9-521" parent="1" style="shape=note;strokeWidth=2;fontSize=14;size=20;whiteSpace=wrap;html=1;fillColor=#647687;strokeColor=#314354;fontColor=#ffffff;align=left;" value="&lt;span style=&quot;font-size: 56px;&quot;&gt;For return, you should also attach an addenda with code 99.&lt;/span&gt;" vertex="1">
          <mxGeometry height="300" width="870" x="11870.67" y="2350" as="geometry" />
        </mxCell>
        <mxCell id="kZJG9KBWsuVOy66hwry9-522" parent="1" style="shape=note;strokeWidth=2;fontSize=14;size=20;whiteSpace=wrap;html=1;fillColor=#a0522d;strokeColor=#6D1F00;fontColor=#ffffff;align=left;" value="&lt;div&gt;&lt;span style=&quot;font-size: 56px;&quot;&gt;It&#39;s not the way that real banks operate but this will hopefully make the return process easier.&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="410" width="870" x="12780" y="3920" as="geometry" />
        </mxCell>
        <mxCell id="kZJG9KBWsuVOy66hwry9-523" edge="1" parent="1" source="kZJG9KBWsuVOy66hwry9-506" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0;entryY=0.5;entryDx=0;entryDy=0;entryPerimeter=0;startSize=50;endSize=50;strokeWidth=12;fillColor=#76608a;strokeColor=#432D57;" target="kZJG9KBWsuVOy66hwry9-520">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="10270" y="3660" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="kZJG9KBWsuVOy66hwry9-524" parent="1" style="shape=note;strokeWidth=2;fontSize=14;size=20;whiteSpace=wrap;html=1;fillColor=#647687;strokeColor=#314354;fontColor=#ffffff;align=left;" value="&lt;span style=&quot;font-size: 56px;&quot;&gt;As mentioned, you&#39;re not required to implement the SFTP connection from your system to ACH. You can place the .ach files inside your folders manually using filezilla or terminal&lt;/span&gt;" vertex="1">
          <mxGeometry height="440" width="870" x="10420" y="1730" as="geometry" />
        </mxCell>
        <mxCell id="kZJG9KBWsuVOy66hwry9-525" edge="1" parent="1" source="kZJG9KBWsuVOy66hwry9-502" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0.413;entryY=-0.002;entryDx=0;entryDy=0;entryPerimeter=0;fillColor=#6d8764;strokeColor=#3A5431;strokeWidth=6;" target="kZJG9KBWsuVOy66hwry9-524">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="10780" y="760" />
              <mxPoint x="10780" y="1690" />
              <mxPoint x="10779" y="1690" />
            </Array>
          </mxGeometry>
        </mxCell>
