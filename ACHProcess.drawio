        <mxCell id="kZJG9KBWsuVOy66hwry9-124" parent="kZJG9KBWsuVOy66hwry9-1" style="swimlane;" value="This is what the file should look like for these transactions" vertex="1">
          <mxGeometry height="420" width="760" x="1590" y="350" as="geometry" />
        </mxCell>
        <mxCell id="kZJG9KBWsuVOy66hwry9-296" parent="kZJG9KBWsuVOy66hwry9-124" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=default;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/png,;" value="" vertex="1">
          <mxGeometry height="384" width="736" x="10" y="30" as="geometry" />
        </mxCell>
        <mxCell id="kZJG9KBWsuVOy66hwry9-132" parent="kZJG9KBWsuVOy66hwry9-1" style="verticalLabelPosition=bottom;html=1;verticalAlign=top;align=center;strokeColor=none;fillColor=#00BEF2;shape=mxgraph.azure.file_2;pointerEvents=1;spacing=0;whiteSpace=wrap;" value="&lt;span style=&quot;white-space: normal;&quot;&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;Get the .ach file&lt;/font&gt;&lt;/span&gt;" vertex="1">
          <mxGeometry height="70" width="70" x="1780" y="245" as="geometry" />
        </mxCell>
        <mxCell id="kZJG9KBWsuVOy66hwry9-23" parent="1" style="shape=note;strokeWidth=2;fontSize=14;size=20;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#666600;" value="ACH operates on batches which are usually sent at a specific time of day. This means you, as bank, are responsible for collecting the transactions until they are ready to be sent.&lt;div&gt;You usually send just 1 file to ACH system&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(102, 102, 0), rgb(162, 162, 74));&quot;&gt;.&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="110" width="390" x="60" y="90" as="geometry" />
        </mxCell>
        <mxCell id="kZJG9KBWsuVOy66hwry9-27" parent="1" style="swimlane;whiteSpace=wrap;html=1;" value="Minimal Ach file data" vertex="1">
          <mxGeometry height="640" width="1080" x="690" y="-440" as="geometry" />
        </mxCell>
        <mxCell id="kZJG9KBWsuVOy66hwry9-28" parent="kZJG9KBWsuVOy66hwry9-27" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=default;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/png,;" value="" vertex="1">
          <mxGeometry height="332" width="319" x="15" y="110" as="geometry" />
        </mxCell>
        <mxCell id="kZJG9KBWsuVOy66hwry9-29" parent="kZJG9KBWsuVOy66hwry9-27" style="shape=note;strokeWidth=2;fontSize=14;size=20;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#666600;" value="Header is usually the same for every file.&lt;div&gt;Just replace the origin with your data, and make sure destination is ACH operator (in this case FRB Tungsten 090000515).&lt;/div&gt;&lt;div&gt;You can change the RTNs and names in .env file&lt;/div&gt;" vertex="1">
          <mxGeometry height="80" width="500" x="345" y="121" as="geometry" />
        </mxCell>
        <mxCell id="kZJG9KBWsuVOy66hwry9-30" parent="kZJG9KBWsuVOy66hwry9-27" style="shape=note;strokeWidth=2;fontSize=14;size=20;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#666600;" value="File can have multiple batches. Header contains information about the sender.&amp;nbsp;&lt;div&gt;company_identification(max. 10 digits) is not the same as bank account(max. 17 digits).&amp;nbsp;&lt;/div&gt;&lt;div&gt;PPD -&amp;gt; Prearranged payment and deposit, usually used for customer transactions&lt;/div&gt;&lt;div&gt;CCD -&amp;gt; Corporate credit or debit, usually used for business-to-business transactions.&lt;/div&gt;" vertex="1">
          <mxGeometry height="130" width="500" x="345" y="211" as="geometry" />
        </mxCell>
        <mxCell id="kZJG9KBWsuVOy66hwry9-31" parent="kZJG9KBWsuVOy66hwry9-27" style="shape=note;strokeWidth=2;fontSize=14;size=20;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#666600;" value="Each batch can have multiples entries, amount is in cents so in this example it&#39;s a $1 transaction. Again dfi_account_number(max. 17 digits) is not the same as company_identification(max. 10 digits).&amp;nbsp;&lt;div&gt;Transaction codes are:&lt;/div&gt;&lt;div&gt;22 -&amp;gt; Credit to checking account (Baguette Store sends money to Leek store)&lt;/div&gt;&lt;div&gt;27 -&amp;gt; Debit&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(102, 102, 0), rgb(162, 162, 74));&quot;&gt;to checking accout&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(102, 102, 0), rgb(162, 162, 74));&quot;&gt;(Baguette Store request money from Leek store)&lt;/span&gt;&lt;/div&gt;&lt;div&gt;32 -&amp;gt; Credit, same as 22 but to savings account&lt;/div&gt;&lt;div&gt;37 -&amp;gt; Debit, same as 27 but to savings account&lt;/div&gt;" vertex="1">
          <mxGeometry height="140" width="500" x="345" y="351" as="geometry" />
        </mxCell>
        <mxCell id="kZJG9KBWsuVOy66hwry9-33" parent="kZJG9KBWsuVOy66hwry9-27" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=default;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/png,;" value="" vertex="1">
          <mxGeometry height="129.23" width="274" x="15" y="461" as="geometry" />
        </mxCell>
        <mxCell id="kZJG9KBWsuVOy66hwry9-32" parent="kZJG9KBWsuVOy66hwry9-27" style="shape=note;strokeWidth=2;fontSize=14;size=20;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#666600;" value="Optional: Each entry can have an addenda (additional information about payment). check full sample for examples" vertex="1">
          <mxGeometry height="100" width="360" x="375" y="521" as="geometry" />
        </mxCell>
        <mxCell id="kZJG9KBWsuVOy66hwry9-34" edge="1" parent="kZJG9KBWsuVOy66hwry9-27" source="kZJG9KBWsuVOy66hwry9-32" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=1.001;entryY=0.847;entryDx=0;entryDy=0;entryPerimeter=0;" target="kZJG9KBWsuVOy66hwry9-33">
          <mxGeometry relative="1" as="geometry" />
